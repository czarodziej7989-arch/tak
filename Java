package com.example.myapplication;

import android.os.Bundle;
import android.view.View;
import android.widget.*;

import androidx.appcompat.app.AppCompatActivity;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.example.myapplication.Wydatek;

import java.util.ArrayList;

public class MainActivity extends AppCompatActivity
        implements View.OnClickListener, WydatekAdapter.OnWydatekActionListener {

    private final ArrayList<Wydatek> listaWydatkow = new ArrayList<>();

    private EditText poleNazwaWydatku;
    private EditText poleKwotaWydatku;
    private Spinner spinnerKategoria;
    private Button przyciskZapisz;

    private WydatekAdapter adapter;
    private TextView tekstPodsumowanie;
    private TextView tekstPustaLista;
    private RecyclerView listaRecyclerView;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        poleNazwaWydatku = findViewById(R.id.poleNazwaWydatku);
        poleKwotaWydatku = findViewById(R.id.poleKwotaWydatku);
        spinnerKategoria = findViewById(R.id.spinnerKategoria);
        przyciskZapisz = findViewById(R.id.przyciskZapisz);

        tekstPodsumowanie = findViewById(R.id.tekstPodsumowanie);
        tekstPustaLista = findViewById(R.id.tekstPustaLista);
        listaRecyclerView = findViewById(R.id.listaWydatkow);

        adapter = new WydatekAdapter(listaWydatkow, this);
        listaRecyclerView.setLayoutManager(new LinearLayoutManager(this));
        listaRecyclerView.setAdapter(adapter);

        przyciskZapisz.setOnClickListener(this);

        odswiezPodsumowanie();
    }

    @Override
    public void onClick(View view) {
        String nazwa = poleNazwaWydatku.getText().toString().trim();
        String kwotaTekst = poleKwotaWydatku.getText().toString().trim();
        String kategoria = spinnerKategoria.getSelectedItem().toString();

        if (nazwa.isEmpty() || kwotaTekst.isEmpty()) {
            Toast.makeText(this, "Uzupełnij pola!", Toast.LENGTH_SHORT).show();
            return;
        }

        double kwota;
        try {
            kwota = Double.parseDouble(kwotaTekst);
        } catch (NumberFormatException e) {
            Toast.makeText(this, "Zła kwota!", Toast.LENGTH_SHORT).show();
            return;
        }

        Wydatek wydatek = new Wydatek(nazwa, kwota, kategoria);

        adapter.dodajWydatek(wydatek);
        listaRecyclerView.smoothScrollToPosition(adapter.getItemCount() - 1);

        wyczyscFormularz();
        odswiezPodsumowanie();
    }

    @Override
    public void onDeleteClicked(int position) {
        adapter.usunWydatek(position);
        odswiezPodsumowanie();
    }

    @Override
    public void onItemClicked(Wydatek wydatek) {
        Toast.makeText(this,
                "Kliknięto: " + wydatek.getNazwa(),
                Toast.LENGTH_SHORT).show();
    }

    private void odswiezPodsumowanie() {
        int liczba = listaWydatkow.size();
        double suma = 0;

        for (Wydatek w : listaWydatkow) {
            suma += w.getKwota();
        }

        tekstPodsumowanie.setText(
                "Wydatki: " + liczba + " | Suma: " +
                        String.format("%.2f zł", suma)
        );

        if (liczba == 0) {
            tekstPustaLista.setVisibility(View.VISIBLE);
        } else {
            tekstPustaLista.setVisibility(View.GONE);
        }
    }

    private void wyczyscFormularz() {
        poleNazwaWydatku.setText("");
        poleKwotaWydatku.setText("");
        spinnerKategoria.setSelection(0);
    }
}
