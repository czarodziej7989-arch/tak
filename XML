<resources>
    <string name="app_name">MenedzerWydatkow</string>
    <string name="zapisz_wydatek">Zapisz wydatek</string>

    <string-array name="kategorie_wydatkow">
        <item>Jedzenie</item>
        <item>Transport</item>
        <item>Rozrywka</item>
        <item>Rachunki</item>
        <item>Inne</item>
    </string-array>
</resources>
/////////////////////////////////////
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tekstNaglowek"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dodaj nowy wydatek"
        android:textSize="20sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/poleNazwaWydatku"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Nazwa wydatku"
        app:layout_constraintTop_toBottomOf="@id/tekstNaglowek"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <EditText
        android:id="@+id/poleKwotaWydatku"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Kwota, np. 15.50"
        android:inputType="numberDecimal"
        app:layout_constraintTop_toBottomOf="@id/poleNazwaWydatku"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <Spinner
        android:id="@+id/spinnerKategoria"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:entries="@array/kategorie_wydatkow"
        app:layout_constraintTop_toBottomOf="@id/poleKwotaWydatku"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <Button
        android:id="@+id/przyciskZapisz"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/zapisz_wydatek"
        app:layout_constraintTop_toBottomOf="@id/spinnerKategoria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>
    <TextView
        android:id="@+id/tekstPodsumowanie"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Wydatki: 0 | Suma: 0,00 zł"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/przyciskZapisz"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tekstPustaLista"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Brak zapisanych wydatków"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tekstPodsumowanie"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listaWydatkow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tekstPustaLista"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
////////////////////////////////////////////////////////////
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">
        <TextView
            android:id="@+id/tekstNazwa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tekstKwota"/>

        <TextView
            android:id="@+id/tekstKategoria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tekstNazwa"
            app:layout_constraintStart_toStartOf="@id/tekstNazwa"
            app:layout_constraintEnd_toEndOf="@id/tekstNazwa"/>

        <TextView
            android:id="@+id/tekstKwota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="@id/tekstNazwa"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/przyciskUsun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuń"
            app:layout_constraintTop_toBottomOf="@id/tekstKwota"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
